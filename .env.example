# Configuración del servicio (Fase 8). Copia a `.env` (local, NO se commitea) y
# rellena. En Render se cargan como Environment Variables.

# --- Google: cuenta de servicio (SOLO lee el Sheet + allowlist) ---
# El CONTENIDO del JSON de la cuenta de servicio (en Render se pega completo).
GOOGLE_SERVICE_ACCOUNT_JSON=
# Carpeta de trabajo (contiene el/los Sheet). Compartida con el email de la SA (Editor).
INPUT_FOLDER_ID=1xpczAIWadBonuVFXnVhCoLYZT1s3KLMU

# --- Google OAuth-as-user (sube el PDF; queda a nombre del usuario, drive.file) ---
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REFRESH_TOKEN=
# Carpeta de resultados (creada por OAuth-as-user, app-owned).
RESULTS_FOLDER_ID=1D9OPIQ__fNzn5fkaDBc3Yk-wOt1MoxGm

# --- Gemini (IA / hallazgos) ---
GEMINI_API_KEY=

# --- Webhook / seguridad ---
# Mismo valor en Apps Script (Script Properties). Generado con secrets.token_urlsafe.
WEBHOOK_SECRET=
RATE_MAX=10

# --- Email de alertas de fallo (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
